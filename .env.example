# ---- HTTP API ----
API_ADDR=:8080
API_KEY=dev-api-key-change-me

# ---- Postgres ----
POSTGRES_USER=notif
POSTGRES_PASSWORD=notifpass
POSTGRES_DB=notifications
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_SSLMODE=disable

# ---- Redis (shared for queue + cache + rate-limit) ----
REDIS_ADDR=redis:6379

# ---- SMTP (MailHog in dev) ----
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=notifications@example.com

# ---- Slack webhook (local mock in dev) ----
SLACK_WEBHOOK_URL=http://slack-mock:9000/webhook

# ---- Logging ----
LOG_LEVEL=info

# ---- Postgres pool ----
POSTGRES_MAX_CONNS=20
POSTGRES_MIN_CONNS=2

# ---- Redis pool ----
REDIS_POOL_SIZE=20

# ---- Worker ----
WORKER_CONCURRENCY=20

# ---- Reconciler ----
RECONCILER_BATCH_SIZE=1000
RECONCILER_INTERVAL_SECONDS=30
RECONCILER_STUCK_AFTER_SECONDS=30

# ---- Rate limit ----
RATE_LIMIT_PER_MINUTE=60

# ---- CORS ----
# * or empty = permissive (any origin); required for web/in-app-demo.html
# opened from file://. Production deployments MUST set this to a concrete
# comma-separated list — e.g. "https://app.example.com,https://admin.example.com".
CORS_ALLOW_ORIGINS=*
